<!DOCTYPE html>
<html lang="uk">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <title>Книгарня</title>
    <link rel="stylesheet" href="/output.css">
    <link rel="stylesheet" href="/viewer.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Merriweather:ital,opsz,wght@0,18..144,300..900;1,18..144,300..900&display=swap"
        rel="stylesheet">
    <script defer src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>
    <script defer>
        window.pdfFilePath = "<%= file.filepath %>";
    </script>
    <script defer src="/viewer.js"></script>
</head>

<body>
    <div class="book-info mb-6">
        <h2 class="mb-4">
            <%= file.filename %>
        </h2>
        <p class="mb-4">
            <%= file.description %>
        </p>
        <p class="mb-4">
            Автор: <%= file.author %>
        </p>
        <p class="mb-4">
            Жанри:
            <% if (file.genres && file.genres.length> 0) { %>
                <%= file.genres.map(g=> g.name).join(", ") %>
                    <% } else { %>
                        Невідомо
                        <% } %>
        </p>
        <div class="back-button">
            <a href="/" class="btn">Назад до списку книг</a>
        </div>
    </div>
    <div id="pdf-container" class="mb-4"></div>
    <div id="page-controls" class="mb-4">
        <button id="prev-page">Минула</button>
        <span id="page-num">Сторінка 1</span>
        <button id="next-page">Наступна</button>
        <input type="number" id="go-to-page-input" placeholder="Перейти на сторінку">
        <button id="go-to-page-btn">Перейти</button>
    </div>
    <div class="mb-4">
        <button id="zoom-out">Віддалити</button>
        <button id="zoom-in">Наблизити</button>
    </div>
</body>

</html>